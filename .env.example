# Neon guide:
# - DATABASE_URL: pooled connection string (contains `-pooler` host)
# - DIRECT_URL: direct connection string (no `-pooler`) for Prisma CLI/migrations
DATABASE_URL="postgresql://user:password@ep-example-123456-pooler.us-east-2.aws.neon.tech/neondb?sslmode=require&channel_binding=require"
DIRECT_URL="postgresql://user:password@ep-example-123456.us-east-2.aws.neon.tech/neondb?sslmode=require&channel_binding=require"

# For non-Neon local Postgres, both can point to the same URL.
# DATABASE_URL="postgresql://user:password@localhost:5432/sewai_metrics"
# DIRECT_URL="postgresql://user:password@localhost:5432/sewai_metrics"

# Optional: use direct (non-pooler) SEWAI URL for metadata fetches if pooler is unstable.
# SEWAI_DIRECT_URL="postgresql://user:password@ep-example-123456.us-east-2.aws.neon.tech/neondb?sslmode=require&channel_binding=require"
SEWAI_DATABASE_URL="postgresql://user:password@localhost:5432/sewai_app?sslmode=require&channel_binding=require"

# Optional webhook security
POSTHOG_WEBHOOK_SECRET=""
